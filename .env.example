# Database
DB_USER=mybooklist
DB_PASSWORD=changeme
DB_HOST=postgres
DB_PORT=5432
DB_NAME=mybooklist

# DATABASE_URL é montada manualmente combinando as variáveis acima.
# Atualizar se mudar DB_USER, DB_PASSWORD, DB_HOST, DB_PORT ou DB_NAME.
DATABASE_URL=postgres://mybooklist:changeme@postgres:5432/mybooklist?sslmode=disable

# Autenticação JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_REFRESH_SECRET=change-this-to-another-long-random-secret

# APIs externas
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# SMTP (opcional — para funcionalidades de e-mail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=your-smtp-password
